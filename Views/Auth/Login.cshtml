@model LoginViewModel
@{ ViewData["Title"] = "Login"; }

<div class="container">
    <div class="form-box">
        <h2>Login</h2>
        <form asp-action="Login" method="post">
            <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

            <div class="form-group">
                <label asp-for="Email"></label>
                <input asp-for="Email" class="form-control" placeholder="your@email.com" />
                <span asp-validation-for="Email" class="field-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="Password"></label>
                <input asp-for="Password" class="form-control" placeholder="••••••••" />
                <span asp-validation-for="Password" class="field-error"></span>
            </div>

            <button type="submit" class="btn btn-full">Login</button>
        </form>

        <div class="form-footer">
            <p>Don't have an account? <a asp-controller="Auth" asp-action="Register">Register here</a></p>
            <hr />
            <p class="hint"><strong>Demo credentials:</strong><br />
                Admin: admin@library.com / admin123<br />
                Member: rahim@email.com / member123
            </p>
        </div>
    </div>
</div>
