@model BookFormViewModel
@{ ViewData["Title"] = "Add Book"; }

<div class="container">
    <div class="form-box form-box--wide">
        <h2>Add New Book</h2>
        <form asp-action="AddBook" method="post" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

            <div class="form-row">
                <div class="form-group">
                    <label asp-for="Title"></label>
                    <input asp-for="Title" class="form-control" />
                    <span asp-validation-for="Title" class="field-error"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Author"></label>
                    <input asp-for="Author" class="form-control" />
                    <span asp-validation-for="Author" class="field-error"></span>
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label asp-for="Genre"></label>
                    <input asp-for="Genre" class="form-control" placeholder="Fiction, Technology, History..." />
                    <span asp-validation-for="Genre" class="field-error"></span>
                </div>
                <div class="form-group">
                    <label asp-for="ISBN"></label>
                    <input asp-for="ISBN" class="form-control" placeholder="978-XXXXXXXXXX" />
                    <span asp-validation-for="ISBN" class="field-error"></span>
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label asp-for="Publisher"></label>
                    <input asp-for="Publisher" class="form-control" />
                </div>
                <div class="form-group">
                    <label asp-for="PublishedYear"></label>
                    <input asp-for="PublishedYear" class="form-control" type="number" placeholder="2024" />
                    <span asp-validation-for="PublishedYear" class="field-error"></span>
                </div>
            </div>

            <div class="form-group">
                <label asp-for="TotalCopies"></label>
                <input asp-for="TotalCopies" class="form-control" type="number" min="1" />
                <span asp-validation-for="TotalCopies" class="field-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="Summary"></label>
                <textarea asp-for="Summary" class="form-control" rows="4"></textarea>
            </div>

            <div class="form-group">
                <label asp-for="CoverImage">Cover Image (optional)</label>
                <input asp-for="CoverImage" type="file" class="form-control" accept="image/*" />
            </div>

            <div class="form-actions">
                <button type="submit" class="btn">Add Book</button>
                <a asp-action="Books" class="btn btn-outline">Cancel</a>
            </div>
        </form>
    </div>
</div>
